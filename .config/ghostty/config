window-decoration = none
window-width = 100
window-height = 30
background-opacity = .75
font-family = LigaHack Nerd Font
font-size = 13

theme = Paul Millr
# title = Ghostty
# window-subtitle = working-directory

shell-integration-features = no-cursor
cursor-style-blink = true
cursor-style = underline
custom-shader = ~/.config/ghostty/shaders/cursor_warp.glsl
custom-shader-animation = always
cursor-color = #999999
cursor-opacity = .75

mouse-hide-while-typing = true
focus-follows-mouse = true

copy-on-select = clipboard
app-notifications = no-clipboard-copy

bell-features = attention, no-title

window-inherit-working-directory = false
tab-inherit-working-directory = false
split-inherit-working-directory = true
window-inherit-font-size = true

keybind = alt+t=unbind
keybind = ctrl+shift+o=unbind
keybind = ctrl+shift+e=unbind
keybind = ctrl+shift+t=unbind

keybind = ctrl+shift+d=new_tab
keybind = ctrl+shift+w=close_surface

keybind = alt+d=new_split:auto
keybind = alt+shift+d=new_split:down
keybind = alt+ctrl+d=new_split:right
keybind = alt+shift+c=toggle_split_zoom
keybind = ctrl+shift+l=goto_split:previous
keybind = ctrl+shift+;=goto_split:next
