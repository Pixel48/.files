{
  "$schema": "https://opencode.ai/tui.json",
  "keybinds": {
    "agent_cycle": "tab",
    "agent_cycle_reverse": "shift+tab",
    "agent_list": "alt+a",
    "app_exit": "ctrl+c,ctrl+d,<leader>q",
    "editor_open": "<leader>e,alt+e",
    "history_next": "down",
    "history_previous": "up",
    "input_clear": "ctrl+c",
    "input_newline": "shift+enter",
    "input_paste": "ctrl+v",
    "input_submit": "enter",
    "leader": "ctrl+space",
    "messages_copy": "alt+y,<leader>y",
    "messages_half_page_down": "ctrl+j",
    "messages_half_page_up": "ctrl+k",
    "messages_last": "ctrl+h",
    "messages_last_user": "ctrl+l",
    "messages_redo": "alt+shift+z,alt+shift+u,<leader>r",
    "messages_undo": "alt+u,alt+z,<leader>u",
    "model_list": "alt+m",
    "session_child_cycle": "ctrl+o",
    "session_child_cycle_reverse": "ctrl+i",
    "session_child_first": "ctrl+u",
    "session_compact": "alt+c",
    "session_export": "ctrl+s",
    "session_fork": "alt+n",
    "session_interrupt": "escape",
    "session_list": "alt+l",
    "session_new": "ctrl+n",
    "session_parent": "ctrl+p",
    "session_timeline": "ctrl+y",
    "sidebar_toggle": "ctrl+b",
    "status_view": "alt+shift+s,<leader>s",
    "terminal_title_toggle": "ctrl+t",
    "theme_list": "alt+shift+t,<leader>t",
    "variant_cycle": "alt+t"
  }
}
